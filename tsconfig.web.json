{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/domain/**/*",
    "src/shared/**/*",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@domain/*": [
        "./src/domain/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ]
    }
  }
}
